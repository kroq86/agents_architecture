APP_ENV=local
APP_NAME=minimal-local-ai-agent
DATABASE_URL=sqlite+aiosqlite:///./local.db
# Local Postgres (see `docker-compose.postgres.yml` at repo root):
# DATABASE_URL=postgresql+asyncpg://agent:agent@127.0.0.1:5432/agent

# openai|mock
LLM_PROVIDER=openai
OPENAI_API_KEY=your_key_here
OPENAI_MODEL=gpt-4.1-mini

OTEL_SERVICE_NAME=minimal-local-ai-agent
# console|otlp
OTEL_TRACES_EXPORTER=console
MAX_RETRY_ATTEMPTS=2
MAX_TOOL_CALLS_PER_RUN=1
OPENAI_MODEL_PRICES_JSON={"gpt-4.1-mini":{"input_per_1k":0.0004,"output_per_1k":0.0016}}

# §5.1 in-app rate limit on POST /chat (set true in prod; use API gateway in prod too)
RATE_LIMIT_ENABLED=false
CHAT_RATE_LIMIT=120/minute

# Browser CORS: comma-separated origins; leave empty to disable CORS middleware
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional API key for /chat, /runs/*, /reviews* (unset = no check). Use X-API-Key or Authorization: Bearer
# API_KEY=

# production: generic 500 messages; local: include exception text in JSON
# APP_ENV=local

